# Production environment template. Copy to .env.prod and fill in real secrets.
# IMPORTANT: NEXT_PUBLIC_API_URL is baked into the frontend at build time.
# Changing it requires rebuilding the frontend image.

# ---- Postgres ----
POSTGRES_USER=quantvision
POSTGRES_PASSWORD=__CHANGE_ME__
POSTGRES_DB=quantvision

# ---- Backend ----
DATABASE_URL=postgresql+psycopg://quantvision:__CHANGE_ME__@db:5432/quantvision
CORS_ORIGINS=https://your-domain.example.com
LOG_LEVEL=INFO
ADMIN_TOKEN=__CHANGE_ME_TO_LONG_RANDOM_HEX__
UVICORN_WORKERS=4

# ---- Frontend (baked at build time) ----
NEXT_PUBLIC_API_URL=https://api.your-domain.example.com
