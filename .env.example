# Copy to .env and fill in for local dev. Do NOT commit the real .env.

# ---- Backend ----
DATABASE_URL=postgresql+psycopg://quantvision:quantvision@db:5432/quantvision
DATABASE_URL_LOCAL=postgresql+psycopg://quantvision:quantvision@localhost:5432/quantvision
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# Token gate for /api/admin/* routes
ADMIN_TOKEN=change-me-to-a-long-random-string

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---- Postgres (used by docker-compose) ----
POSTGRES_USER=quantvision
POSTGRES_PASSWORD=quantvision
POSTGRES_DB=quantvision
